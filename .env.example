# LocalStack (optional - used by docker-compose)
# Copy to .env and adjust if needed.

# Serviços a subir (default: só apigateway para teste)
# Ex.: apigateway | ec2,ecr,eks,rds,iam,sts,apigateway (stack completo)
SERVICES=apigateway

# Debug logging (0 = off, 1 = on)
DEBUG=0

# Persist data between restarts (0 = off, 1 = on)
PERSISTENCE=0
